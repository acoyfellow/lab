# Copy to `.env` and fill in. Never commit real secrets.

# -----------------------------------------------------------------------------
# Better Auth (SvelteKit + D1). Required for the app to run with auth.
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=
# Public URL of the app (OAuth callback base). Alchemy defaults deploy env; use local dev URL when running vite.
# BETTER_AUTH_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Alchemy deploy (`bun run deploy` / CI)
# See https://alchemy.run/guides/cloudflare-state-store/ for ALCHEMY_STATE_TOKEN.
# -----------------------------------------------------------------------------
# ALCHEMY_PASSWORD=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# ALCHEMY_STATE_TOKEN=
#
# If your shell exports a work/default Cloudflare account, `bun run dev` also
# honors these personal overrides before falling back to CLOUDFLARE_*.
# CLOUDFLARE_PERSONAL_API_TOKEN=
# CLOUDFLARE_PERSONAL_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Local dogfood: `@acoyfellow/lab` against a Lab Worker.
# -----------------------------------------------------------------------------
# `bun run dev` starts the local Worker on :1337.
# LAB_URL=http://localhost:1337
#
# UI-only dev (`bun run dev:ui`) can point Compose/results at any running Worker
# without starting Alchemy locally.
# LAB_WORKER_ORIGIN=https://lab.coey.dev

# -----------------------------------------------------------------------------
# Examples page: optional stable link to a real trace (deploy / .dev.vars)
# -----------------------------------------------------------------------------
# PUBLIC_EXAMPLE_TRACE_ID=

# Optional: disable Alchemy CLI telemetry
# ALCHEMY_TELEMETRY_DISABLED=1
# DO_NOT_TRACK=1
