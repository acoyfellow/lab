{
  "name": "@acoyfellow/lab-cli",
  "version": "0.0.3",
  "description": "Minimal CLI for Lab — agents shell out, get saved results back",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "lab": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@acoyfellow/lab": "^0.0.3",
    "effect": "4.0.0-beta.51"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
