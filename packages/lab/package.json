{
  "name": "@acoyfellow/lab",
  "version": "0.0.3",
  "description": "Typed HTTP client for the Lab public app API (sandboxed isolates, chains, saved results)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "import": "./dist/effect.js"
    }
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0 <5"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "effect": "4.0.0-beta.51",
    "typescript": "^5.9.3"
  }
}
