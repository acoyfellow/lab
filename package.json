{
  "name": "lab",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "alchemy dev",
    "dogfood:lab": "bun run build:client && bun scripts/dogfood-lab.ts",
    "pi:lab-bridge": "bun run scripts/pi-lab-bridge.ts",
    "mcp:lab": "bun run --cwd packages/lab-mcp start",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "build": "vite build",
    "build:client": "cd packages/lab && bun run build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "test": "bun test",
    "lint": "oxlint . --deny-warnings",
    "check": "svelte-kit sync && bun run build:client && bun run --cwd packages/lab-mcp typecheck && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:better-auth": "bunx @better-auth/cli generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:local": "wrangler d1 migrations apply lab-db --local",
    "db:remote": "wrangler d1 migrations apply lab-db --remote"
  },
  "devDependencies": {
    "@acoyfellow/lab": "workspace:*",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "acorn": "^8.16.0",
    "drizzle-kit": "^0.31.10",
    "mdsvex": "^0.12.7",
    "oxlint": "^1.57.0",
    "remark-gfm": "^4.0.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@types/node": "^25.5.0",
    "alchemy": "^0.82.1",
    "better-auth": "1.4.7",
    "drizzle-orm": "^0.45.1",
    "effect": "4.0.0-beta.40",
    "shiki": "^4.0.2"
  },
  "type": "module"
}
